# Environment / secrets
.env
.env.*
!.env.example
!.env.*.example

# Node
node_modules/
dist/
build/
.next/
.nuxt/
.expo/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs / local tooling artifacts
*.log
.playwright-mcp/

# Deploy keys (never commit private keys)
deploy/keys/**
!deploy/keys/.gitignore

# Django/Backend user uploads (local/dev artifacts)
flowteam_backend/media/**
!flowteam_backend/media/.gitkeep

# Prevent committing nested repos
**/.git/
