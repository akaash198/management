SECRET_KEY=django-insecure-replace-this-with-a-real-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=flowteam
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Redis (channels/celery/cache)
REDIS_URL=redis://localhost:6379

# Frontend (used for invite links in emails)
FRONTEND_BASE_URL=http://localhost:3000

# Email (dev uses console backend by default; configure SMTP for real delivery)
DEFAULT_FROM_EMAIL=no-reply@flowteam.local
EMAIL_HOST=localhost
EMAIL_PORT=25
