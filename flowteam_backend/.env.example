# EMAIL_USE_SSL=False

# Stripe billing (required for plan upgrades)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=

# S3/R2 storage (requires django-storages + boto3 installed)
# USE_S3_STORAGE=False
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
