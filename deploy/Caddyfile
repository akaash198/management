app.cowrkflow.com {
    encode gzip

    @api path /api/* /api
    reverse_proxy @api backend:8000

    @ws path /ws/*
    reverse_proxy @ws backend:8000

    handle_path /media/* {
        root * /media
        file_server
    }

    reverse_proxy frontend:3000
}

:80 {
    redir https://{host}{uri} permanent
}
