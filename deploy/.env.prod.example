# Copy to /opt/flowteam/.env.prod and fill in values.
POSTGRES_DB=flowteam
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Comma-separated hostnames/IPs (include your domain)
ALLOWED_HOSTS=YOUR_SERVER_IP,localhost,127.0.0.1

# Django secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=change-me

# CORS — frontend URL(s) the browser should allow
CORS_ALLOWED_ORIGINS=https://flowteam.example.com

# Email configuration (SMTP)
DEFAULT_FROM_EMAIL=noreply@flowteam.example.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True

# Frontend URL (for email links, OAuth redirects)
FRONTEND_BASE_URL=https://flowteam.example.com

# VAPID keys for web push (generate with: python -c "from pywebpush import generate_vapid_keys; import json; print(json.dumps(generate_vapid_keys()))")
VAPID_PUBLIC_KEY=change-me
VAPID_PRIVATE_KEY=change-me
VAPID_CLAIMS_SUB=mailto:admin@flowteam.example.com

# OAuth providers (fill in your client IDs/secrets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://flowteam.example.com/api/auth/oauth/google/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://flowteam.example.com/api/auth/oauth/github/callback/
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Monitoring
PROMETHEUS_ALLOWED_IPS=127.0.0.1,10.0.0.0/8

# Optional: tweak ASGI server
USE_UVICORN=1
UVICORN_WORKERS=2

# Optional: Sentry for error tracking
SENTRY_DSN=
