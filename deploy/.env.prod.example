# Copy to /opt/flowteam/.env.prod and fill in values.
POSTGRES_DB=flowteam
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Comma-separated hostnames/IPs (include your domain)
ALLOWED_HOSTS=YOUR_SERVER_IP,localhost,127.0.0.1

# Django secret key
SECRET_KEY=change-me

# Optional: tweak ASGI server
USE_UVICORN=1
UVICORN_WORKERS=2
